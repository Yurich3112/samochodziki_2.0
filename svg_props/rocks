<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rocks Asset Preview</title>
  <style>
    body {
      margin: 0;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #2b3e2e; 
    }
    .asset-container {
      width: 500px;
      height: 200px;
    }
  </style>
</head>
<body>

  <div class="asset-container">
    <!-- SVG Rocks Asset -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 250 100" width="100%" height="100%">
      
      <defs>
        <!-- Reusable Small Rock Definition -->
        <g id="rock-small">
          <polygon points="-4,-9 8,-10 10,-1 9,10 2,11 -1,12 -5,9 -10,-1" fill="rgba(0,0,0,0.35)" transform="translate(2, 3)"/>
          <g stroke="#111213" stroke-width="3" stroke-linejoin="round">
            <polygon points="-4,-9 8,-10 10,-1 1,1" fill="#a2a7aa"/>
            <polygon points="-4,-9 1,1 -5,9 -10,-1" fill="#868a8e"/>
            <polygon points="10,-1 9,10 2,11 1,1" fill="#61666b"/>
            <polygon points="2,11 -1,12 -5,9 1,1" fill="#54595d"/>
          </g>
        </g>

        <!-- Reusable Tiny Rock Definition -->
        <g id="rock-tiny">
          <polygon points="-2,-4 4,-5 5,-0.5 4.5,5 1,5.5 -0.5,6 -2.5,4.5 -5,-0.5" fill="rgba(0,0,0,0.35)" transform="translate(1.5, 2)"/>
          <g stroke="#111213" stroke-width="3" stroke-linejoin="round">
            <polygon points="-2,-4 4,-5 5,-0.5 0.5,0.5" fill="#a2a7aa"/>
            <polygon points="-2,-4 0.5,0.5 -2.5,4.5 -5,-0.5" fill="#868a8e"/>
            <polygon points="5,-0.5 4.5,5 1,5.5 0.5,0.5" fill="#61666b"/>
            <polygon points="1,5.5 -0.5,6 -2.5,4.5 0.5,0.5" fill="#54595d"/>
          </g>
        </g>
      </defs>

      <!-- 1. Large Rock -->
      <g transform="translate(35, 50)">
        <!-- Shadow contour -->
        <polygon points="-12,-22 15,-28 22,-8 18,22 4,24 -8,28 -18,20 -28,-4" fill="rgba(0,0,0,0.35)" transform="translate(4, 5)"/>
        
        <!-- 3D Facets -->
        <g stroke="#111213" stroke-width="3" stroke-linejoin="round">
          <!-- Top Light -->
          <polygon points="-12,-22 15,-28 22,-8 -2,2" fill="#a2a7aa"/>
          <!-- Left Mid -->
          <polygon points="-12,-22 -2,2 -18,20 -28,-4" fill="#868a8e"/>
          <!-- Right Dark -->
          <polygon points="22,-8 18,22 4,24 -2,2" fill="#61666b"/>
          <!-- Bottom Darkest -->
          <polygon points="4,24 -8,28 -18,20 -2,2" fill="#54595d"/>
        </g>
      </g>

      <!-- 2. Medium Rock -->
      <g transform="translate(95, 55)">
        <polygon points="-6,-14 12,-16 16,-2 14,16 3,18 -2,20 -8,14 -16,-2" fill="rgba(0,0,0,0.35)" transform="translate(3, 4)"/>
        <g stroke="#111213" stroke-width="3" stroke-linejoin="round">
          <polygon points="-6,-14 12,-16 16,-2 2,2" fill="#a2a7aa"/>
          <polygon points="-6,-14 2,2 -8,14 -16,-2" fill="#868a8e"/>
          <polygon points="16,-2 14,16 3,18 2,2" fill="#61666b"/>
          <polygon points="3,18 -2,20 -8,14 2,2" fill="#54595d"/>
        </g>
      </g>

      <!-- 3. Small Rock -->
      <use href="#rock-small" transform="translate(145, 60)"/>

      <!-- 4. Tiny Rock -->
      <use href="#rock-tiny" transform="translate(175, 63)"/>

      <!-- 5. Rock Cluster (Overlapping small & tiny rocks) -->
      <g transform="translate(215, 60)">
        <use href="#rock-tiny" transform="translate(-12, -8)"/>
        <use href="#rock-small" transform="translate(6, 2)"/>
        <use href="#rock-tiny" transform="translate(-6, 12)"/>
      </g>

    </svg>
  </div>

</body>
</html>