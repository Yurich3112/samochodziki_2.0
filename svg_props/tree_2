<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Broadleaf Tree Asset Preview</title>
  <style>
    body {
      margin: 0;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #2b3e2e; 
    }
    .tree-container {
      width: 250px;
      height: 250px;
    }
  </style>
</head>
<body>

  <div class="tree-container">
    <!-- SVG Broadleaf Tree Asset -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" width="100%" height="100%">
      
      <defs>
        <!-- Top-down broadleaf canopy silhouette -->
        <g id="broadleaf-layer">
          <circle cx="0" cy="-28" r="18"/>
          <circle cx="24" cy="-14" r="18"/>
          <circle cx="24" cy="14" r="18"/>
          <circle cx="0" cy="28" r="18"/>
          <circle cx="-24" cy="14" r="18"/>
          <circle cx="-24" cy="-14" r="18"/>
          <circle cx="0" cy="0" r="26"/>
        </g>
      </defs>

      <!-- Drop Shadow (Matches UI/track bottom-right lighting) -->
      <g transform="translate(66, 68)">
        <use href="#broadleaf-layer" fill="rgba(0,0,0,0.35)"/>
      </g>

      <!-- Base Layer (Darkest) -->
      <g transform="translate(60, 60)">
        <use href="#broadleaf-layer" fill="#142e1b"/>
      </g>

      <!-- Layer 2 (Rotated 30deg to interleave leaves, shifted top-left) -->
      <g transform="translate(58, 58) scale(0.8) rotate(30)">
        <use href="#broadleaf-layer" fill="#1b3b22"/>
      </g>

      <!-- Layer 3 -->
      <g transform="translate(56, 56) scale(0.6) rotate(60)">
        <use href="#broadleaf-layer" fill="#26522f"/>
      </g>

      <!-- Layer 4 -->
      <g transform="translate(54, 54) scale(0.4) rotate(90)">
        <use href="#broadleaf-layer" fill="#357040"/>
      </g>

      <!-- Layer 5 (Tip Highlight) -->
      <g transform="translate(52, 52) scale(0.2) rotate(120)">
        <use href="#broadleaf-layer" fill="#438c50"/>
      </g>

    </svg>
  </div>

</body>
</html>